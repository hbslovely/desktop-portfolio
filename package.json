{
  "name": "desktop-portfolio",
  "version": "2026.06.13-rc.01",
  "scripts": {
    "ng": "ng",
    "start": "npm run dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:angular\"",
    "dev:angular": "ng serve --port 3006 --proxy-config proxy.conf.json",
    "dev:angular-only": "ng serve",
    "dev:api": "cd server && npm run dev:api",
    "build": "ng build --configuration production",
    "build:plain": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/app/**/*.{ts,html,scss,css}\"",
    "format:check": "prettier --check \"src/app/**/*.{ts,html,scss,css}\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.16",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.2.16",
    "@angular/compiler": "^21.2.16",
    "@angular/core": "^21.2.16",
    "@angular/forms": "^21.2.16",
    "@angular/platform-browser": "^21.2.16",
    "@angular/platform-browser-dynamic": "^21.2.16",
    "@angular/router": "^21.2.16",
    "@hbslovely/baby-feeding": "2026.6.4",
    "chart.js": "^4.5.1",
    "ngx-mask": "^21.0.0",
    "primeng": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.14",
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/schematics": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.16",
    "@ngx-env/builder": "^21.0.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "glob": "^13.0.0",
    "jasmine-core": "~5.1.0",
    "javascript-obfuscator": "^4.1.1",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.4.2",
    "typescript": "~5.9.3",
    "vercel": "^49.1.1",
    "webpack-obfuscator": "^3.5.1"
  }
}
