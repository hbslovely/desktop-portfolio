# Frontend (NG_APP_* — injected at build time by @ngx-env/builder)
NG_APP_GOOGLE_SHEETS_API_KEY=
NG_APP_GOOGLE_CLIENT_ID=
NG_APP_GOOGLE_APPS_SCRIPT_URL=
NG_APP_GOOGLE_FEEDING_APPS_SCRIPT_URL=
NG_APP_GOOGLE_FEEDING_SHEET_ID=
NG_APP_GOOGLE_BUSINESS_APPS_SCRIPT_URL=
NG_APP_GOOGLE_BUSINESS_SHEET_ID=
NG_APP_GOOGLE_EXPENSE_SHEET_ID=
NG_APP_WEATHER_API_KEY=
NG_APP_HUGGINGFACE_TOKEN=

# Server / Vercel API (not prefixed with NG_APP_)
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_BRANCH=
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_BUSINESS_APPS_SCRIPT_URL=
GOOGLE_FEEDING_APPS_SCRIPT_URL=

# GitHub Actions — daily-medical-report workflow
# These are stored as GitHub repository Secrets, not in .env.local
# GOOGLE_SHEETS_API_KEY          = same value as NG_APP_GOOGLE_SHEETS_API_KEY above
# GOOGLE_FEEDING_SHEET_ID        = same value as NG_APP_GOOGLE_FEEDING_SHEET_ID above
# GOOGLE_SERVICE_ACCOUNT_JSON    = full JSON key from Google Cloud service account
#                                  (grant the account "Editor" access to the Drive folder)
